{
  "compilerOptions": {
    "checkJs": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["**/*.js", "**/*.cjs"],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results",
    "artifacts",
    "reports",
    "dist",
    ".tmp"
  ]
}
